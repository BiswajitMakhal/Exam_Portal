<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Live Exam - <%= exam.title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f4f6f9;
            user-select: none;
            /* Text selection disable kora holo */
        }

        .sticky-timer {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(5px);
            border-bottom: 2px solid #0d6efd;
        }

        .question-card {
            border-left: 4px solid #0d6efd;
        }
    </style>
</head>
<!-- oncontextmenu="return false;" diye right click disable kora holo -->

<body oncontextmenu="return false;">

    <!-- Sticky Header with Timer -->
    <div class="sticky-timer shadow-sm py-3 mb-4">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h5 class="mb-0 fw-bold text-dark">
                    <%= exam.title %>
                </h5>
                <small class="text-muted"><i class="bi bi-person"></i>
                    <%= user.name %>
                </small>
            </div>
            <div class="text-end">
                <span class="badge bg-danger fs-5 px-3 py-2" id="timerDisplay">
                    <i class="bi bi-stopwatch"></i> Loading...
                </span>
                <div class="small text-muted mt-1 fw-bold" id="warningDisplay">Warnings: 0 / 3</div>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <!-- Exam Form Start -->
        <form id="examForm" action="/student/exam/submit" method="POST">
            <input type="hidden" name="examId" value="<%= exam._id %>">

            <% if(questions && questions.length> 0) { %>
                <% questions.forEach((q, index)=> { %>
                    <div class="card border-0 shadow-sm mb-4 question-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <h5 class="fw-bold text-dark mb-0">Question <%= index + 1 %>
                                </h5>
                                <span class="badge bg-secondary">
                                    <%= q.marks %> Marks
                                </span>
                            </div>

                            <p class="fs-5 mb-3">
                                <%= q.questionText %>
                            </p>

                            <!-- Question Image jodi thake -->
                            <% if(q.imageUrl) { %>
                                <div class="mb-4">
                                    <img src="<%= q.imageUrl %>" alt="Question Image" class="img-fluid rounded border"
                                        style="max-height: 300px;">
                                </div>
                                <% } %>

                                    <!-- Options -->
                                    <div class="mt-3">
                                        <% q.options.forEach((opt, optIndex)=> { %>
                                            <div class="form-check custom-radio mb-3 border p-3 rounded hover-bg-light">
                                                <!-- Name attribute e question id dewa hoyeche jate backend easily parse korte pare -->
                                                <input class="form-check-input fs-5 mt-1" type="radio"
                                                    name="answers[<%= q._id %>]" id="q<%= index %>_opt<%= optIndex %>"
                                                    value="<%= opt %>">
                                                <label class="form-check-label fs-6 ms-2 w-100" style="cursor: pointer;"
                                                    for="q<%= index %>_opt<%= optIndex %>">
                                                    <%= opt %>
                                                </label>
                                            </div>
                                            <% }) %>
                                    </div>
                        </div>
                    </div>
                    <% }) %>

                        <div class="text-center mt-5">
                            <button type="button" class="btn btn-primary btn-lg px-5 fw-bold"
                                onclick="confirmSubmission()">
                                <i class="bi bi-check2-circle"></i> Submit Exam
                            </button>
                        </div>
                        <% } else { %>
                            <div class="alert alert-warning text-center">
                                No questions available for this exam. Please contact your administrator.
                            </div>
                            <% } %>
        </form>
    </div>

    <!-- SweetAlert for nice popups -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 1. Timer Logic
        let durationInSeconds = <%= exam.duration * 60 %>;
        const timerDisplay = document.getElementById('timerDisplay');
        const examForm = document.getElementById('examForm');

        function updateTimer() {
            let minutes = Math.floor(durationInSeconds / 60);
            let seconds = durationInSeconds % 60;

            // Add leading zeros
            minutes = minutes < 10 ? "0" + minutes : minutes;
            seconds = seconds < 10 ? "0" + seconds : seconds;

            timerDisplay.innerHTML = `<i class="bi bi-stopwatch"></i> ${minutes}:${seconds}`;

            if (durationInSeconds <= 0) {
                clearInterval(timerInterval);
                Swal.fire({
                    title: 'Time is Up!',
                    text: 'Your exam is being submitted automatically.',
                    icon: 'info',
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    timer: 3000
                }).then(() => {
                    examForm.submit();
                });
            } else if (durationInSeconds === 300) { // 5 minutes left warning
                timerDisplay.classList.replace('bg-danger', 'bg-warning');
                timerDisplay.classList.add('text-dark');
            }
            durationInSeconds--;
        }

        const timerInterval = setInterval(updateTimer, 1000);
        updateTimer(); // Initial call

        // 2. Anti-Cheat Logic (Tab Switching)
        let warningCount = 0;
        const maxWarnings = 3;

        document.addEventListener("visibilitychange", () => {
            if (document.hidden) {
                warningCount++;
                document.getElementById('warningDisplay').innerText = `Warnings: ${warningCount} / ${maxWarnings}`;

                if (warningCount >= maxWarnings) {
                    Swal.fire({
                        title: 'Exam Terminated',
                        text: 'You have exceeded the maximum number of tab switches. Your exam is being submitted automatically.',
                        icon: 'error',
                        allowOutsideClick: false,
                        showConfirmButton: false,
                        timer: 4000
                    }).then(() => {
                        examForm.submit();
                    });
                } else {
                    Swal.fire({
                        title: 'Warning!',
                        text: `Do not switch tabs or minimize the browser! Warning ${warningCount} of ${maxWarnings}. Exam will be auto-submitted on the 3rd warning.`,
                        icon: 'warning',
                        confirmButtonText: 'I Understand'
                    });
                }
            }
        });

        // 3. Manual Submit Confirmation
        function confirmSubmission() {
            Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to submit your exam? You won't be able to change your answers.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0d6efd',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Submit!'
            }).then((result) => {
                if (result.isConfirmed) {
                    examForm.submit();
                }
            });
        }
    </script>
</body>

</html>