<%- include('../layouts/header') %>
    <%- include('../layouts/student_navbar') %>

        <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-12 col-md-8 col-lg-6">

                <div class="card border-0 shadow text-center p-4 p-sm-5 custom-card">

                    <% if(result.isPassed) { %>
                        <div class="display-1 text-success mb-3"><i class="bi bi-check-circle-fill"></i></div>
                        <h2 class="fw-bold text-dark">Congratulations!</h2>
                        <p class="text-muted fs-5 mb-4">You have successfully passed the exam.</p>
                        <% } else { %>
                            <div class="display-1 text-danger mb-3"><i class="bi bi-x-circle-fill"></i></div>
                            <h2 class="fw-bold text-dark">Exam Completed</h2>
                            <p class="text-muted fs-5 mb-4">Unfortunately, you did not meet the passing criteria.</p>
                            <% } %>

                                <hr class="text-muted mb-4">

                                <h4 class="fw-bold mb-2">
                                    <%= result.examId.title %>
                                </h4>

                                <div class="p-3 bg-light rounded-3 my-4">
                                    <p class="mb-1 text-secondary fs-5">Your Score</p>
                                    <h1 class="fw-bold text-primary display-4 mb-0">
                                        <%= result.score %> / <%= result.totalMarks %>
                                    </h1>
                                </div>

                                <div class="d-grid gap-2 col-8 mx-auto mt-4">
                                    <a href="/student/dashboard" class="btn btn-primary btn-lg"><i
                                            class="bi bi-house-door me-1"></i> Back to Dashboard</a>
                                </div>

                </div>
            </div>
        </div>

        <style>
            .custom-card {
                border-radius: 15px;
                background: linear-gradient(145deg, #ffffff, #f0f0f0);
            }
        </style>

        <%- include('../layouts/footer') %>