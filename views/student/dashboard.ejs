<%- include('../layouts/header') %>
    <%- include('../layouts/student_navbar') %>

        <div class="container py-5" style="min-height: 80vh;">
            <div class="mb-4">
                <h2 class="fw-bold text-dark"><i class="bi bi-journal-text text-primary"></i> Available Exams</h2>
                <p class="text-muted">Select an exam from the list below to begin.</p>
            </div>

            <!-- Flash Messages -->
            <% if (typeof error !=='undefined' && error) { %>
                <div class="alert alert-danger alert-dismissible fade show">
                    <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>

                    <div class="row g-4">
                        <% if(exams && exams.length> 0) { %>
                            <% exams.forEach(exam=> { %>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="card h-100 border-0 shadow-sm custom-hover-card">
                                        <div class="card-body p-4">
                                            <span class="badge bg-success mb-2"><i
                                                    class="bi bi-circle-fill small me-1"></i>Active</span>
                                            <h5 class="card-title fw-bold text-dark mb-3">
                                                <%= exam.title %>
                                            </h5>
                                            <p class="text-muted small mb-3">
                                                <%= exam.description ? exam.description.substring(0, 80) + '...'
                                                    : 'No description provided.' %>
                                            </p>

                                            <ul class="list-unstyled mb-4">
                                                <li class="mb-2 text-secondary"><i
                                                        class="bi bi-clock text-primary me-2"></i>
                                                    <strong>Duration:</strong>
                                                    <%= exam.duration %> Minutes
                                                </li>
                                                <li class="text-secondary"><i
                                                        class="bi bi-check2-circle text-primary me-2"></i>
                                                    <strong>Passing Marks:</strong>
                                                    <%= exam.passingMarks %>
                                                </li>
                                            </ul>

                                            <div class="d-grid">
                                                <!-- Warning: eta click korlei Live Exam shuru hobe -->
                                                <a href="/student/exam/live/<%= exam._id %>"
                                                    class="btn btn-outline-primary fw-semibold"
                                                    onclick="return confirm('Are you sure you want to start this exam now? The timer will begin immediately.');">
                                                    Start Exam <i class="bi bi-arrow-right-circle ms-1"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="col-12 text-center py-5 bg-white rounded-3 shadow-sm">
                                            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png"
                                                alt="No Exams" style="width: 120px; opacity: 0.6; margin-bottom: 15px;">
                                            <h4 class="text-muted fw-bold">No active exams right now!</h4>
                                            <p class="text-muted">Please check back later or contact your administrator.
                                            </p>
                                        </div>
                                        <% } %>
                    </div>
        </div>

        <style>
            .custom-hover-card {
                transition: transform 0.3s ease, box-shadow 0.3s ease;
            }

            .custom-hover-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
            }
        </style>

        <%- include('../layouts/footer') %>