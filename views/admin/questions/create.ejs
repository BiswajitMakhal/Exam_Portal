<%- include('../../layouts/header') %>

    <div class="container-fluid">
        <div class="row">
            <%- include('../../layouts/sidebar') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="min-height: 100vh;">
                    <%- include('../../layouts/navbar') %>

                        <div
                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-2 mb-4 border-bottom">
                            <h1 class="h3 fw-bold"><i class="bi bi-plus-square-dotted text-primary"></i> Add New
                                Question</h1>
                            <a href="/admin/questions/exam/<%= examId %>" class="btn btn-sm btn-outline-secondary"><i
                                    class="bi bi-arrow-left"></i> Back to Questions</a>
                        </div>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="card p-4 shadow-sm border-0 col-lg-8 mb-4">
                                    <form action="/admin/questions/create" method="POST" enctype="multipart/form-data">
                                        <input type="hidden" name="examId" value="<%= examId %>">

                                        <div class="mb-3">
                                            <label for="questionText" class="form-label fw-semibold">Question Text <span
                                                    class="text-danger">*</span></label>
                                            <textarea class="form-control" id="questionText" name="questionText"
                                                rows="3" placeholder="Write your question here..." required></textarea>
                                        </div>

                                        <div class="mb-4">
                                            <label for="image" class="form-label fw-semibold">Reference Image
                                                (Optional)</label>
                                            <input class="form-control" type="file" id="image" name="image"
                                                accept="image/*">
                                            <div class="form-text">Upload a diagram or image if needed for this
                                                question.</div>
                                        </div>

                                        <h5 class="fw-bold border-bottom pb-2 mb-3">Options & Answer</h5>
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Option 1 <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="options"
                                                    placeholder="First option" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Option 2 <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="options"
                                                    placeholder="Second option" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Option 3 <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="options"
                                                    placeholder="Third option" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Option 4 <span
                                                        class="text-danger">*</span></label>
                                                <input type="text" class="form-control" name="options"
                                                    placeholder="Fourth option" required>
                                            </div>
                                        </div>

                                        <div class="row g-3 mb-4">
                                            <div class="col-md-6">
                                                <label for="correctAnswer" class="form-label fw-semibold">Correct Answer
                                                    <span class="text-danger">*</span></label>
                                                <input type="text" class="form-control" id="correctAnswer"
                                                    name="correctAnswer"
                                                    placeholder="Type the correct option exactly as above" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label for="marks" class="form-label fw-semibold">Marks <span
                                                        class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="marks" name="marks"
                                                    value="1" min="1" required>
                                            </div>
                                        </div>

                                        <div class="mt-2">
                                            <button type="submit" class="btn btn-primary px-4"><i
                                                    class="bi bi-save"></i> Save Question</button>
                                        </div>
                                    </form>
                                </div>
                </main>
        </div>
    </div>

    <%- include('../../layouts/footer') %>