<%- include('../layouts/header') %>

    <div class="container-fluid">
        <div class="row">
            <%- include('../layouts/sidebar') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="min-height: 100vh;">
                    <%- include('../layouts/navbar') %>

                        <div
                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-2 mb-4 border-bottom">
                            <h1 class="h3 fw-bold"><i class="bi bi-grid-1x2-fill text-primary me-2"></i> Dashboard
                                Overview</h1>
                        </div>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                            <% } %>
                                <% if (typeof success !=='undefined' && success) { %>
                                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                                        <%= success %><button type="button" class="btn-close"
                                                data-bs-dismiss="alert"></button>
                                    </div>
                                    <% } %>

                                        <div class="row g-4 mb-4">

                                            <% if(locals.user && locals.user.role==='SuperAdmin' ) { %>
                                                <div class="col-12 col-sm-6 col-xl-3">
                                                    <div class="card border-0 shadow-sm text-center h-100 py-3">
                                                        <div class="card-body">
                                                            <div class="display-5 text-primary mb-2"><i
                                                                    class="bi bi-people-fill"></i></div>
                                                            <h3 class="fw-bold mb-1">
                                                                <%= stats.totalUsers %>
                                                            </h3>
                                                            <p class="text-muted mb-0">Total Users</p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <% } %>

                                                    <div class="col-12 col-sm-6 col-xl-3">
                                                        <div class="card border-0 shadow-sm text-center h-100 py-3">
                                                            <div class="card-body">
                                                                <div class="display-5 text-success mb-2"><i
                                                                        class="bi bi-person-badge-fill"></i></div>
                                                                <h3 class="fw-bold mb-1">
                                                                    <%= stats.totalCandidates %>
                                                                </h3>
                                                                <p class="text-muted mb-0">Total Candidates</p>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 col-sm-6 col-xl-3">
                                                        <div class="card border-0 shadow-sm text-center h-100 py-3">
                                                            <div class="card-body">
                                                                <div class="display-5 text-warning mb-2"><i
                                                                        class="bi bi-file-earmark-text-fill"></i></div>
                                                                <h3 class="fw-bold mb-1">
                                                                    <%= stats.totalExams %>
                                                                </h3>
                                                                <p class="text-muted mb-0">Total Exams</p>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 col-sm-6 col-xl-3">
                                                        <div class="card border-0 shadow-sm text-center h-100 py-3">
                                                            <div class="card-body">
                                                                <div class="display-5 text-danger mb-2"><i
                                                                        class="bi bi-clipboard-check-fill"></i></div>
                                                                <h3 class="fw-bold mb-1">
                                                                    <%= stats.totalSubmissions %>
                                                                </h3>
                                                                <p class="text-muted mb-0">Total Submissions</p>
                                                            </div>
                                                        </div>
                                                    </div>

                                        </div>

                                        <div class="p-4 mb-4 bg-white border-0 shadow-sm rounded-3">
                                            <div class="container-fluid py-2">
                                                <h4 class="fw-bold">Welcome back, <%= locals.user ? locals.user.name
                                                        : 'User' %>!</h4>
                                                <p class="text-muted fs-6">Use the sidebar to manage users, create new
                                                    exams, or check analytics from the system.</p>
                                                <a href="/admin/exams/create" class="btn btn-primary mt-2"><i
                                                        class="bi bi-plus-circle me-1"></i> Create New Exam</a>
                                            </div>
                                        </div>

                </main>
        </div>
    </div>

    <%- include('../layouts/footer') %>