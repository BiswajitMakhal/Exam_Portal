<%- include('../../layouts/header') %>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../layouts/sidebar') %>

                <!-- Main Content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="min-height: 100vh;">
                    <%- include('../../layouts/navbar') %>

                        <div
                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-2 mb-3 border-bottom">
                            <div>
                                <h1 class="h3 fw-bold"><i class="bi bi-bar-chart-fill text-primary me-2"></i> Analytics
                                    & Results</h1>
                                <p class="text-muted mb-0">Select an exam below to view its scoreboard and candidate
                                    performance.</p>
                            </div>
                        </div>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger alert-dismissible fade show">
                                <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                            <% } %>

                                <div class="row g-4 mb-5">
                                    <% if(exams && exams.length> 0) { %>
                                        <% exams.forEach(exam=> { %>
                                            <div class="col-12 col-md-6 col-xl-4">
                                                <div class="card h-100 border-0 shadow-sm custom-card">
                                                    <div class="card-body p-4">
                                                        <div
                                                            class="d-flex justify-content-between align-items-center mb-3">
                                                            <span
                                                                class="badge <%= exam.status === 'Active' ? 'bg-success' : 'bg-danger' %> rounded-pill px-3 py-2">
                                                                <%= exam.status %>
                                                            </span>
                                                            <small class="text-muted fw-bold"><i
                                                                    class="bi bi-stopwatch me-1"></i>
                                                                <%= exam.duration %> Mins
                                                            </small>
                                                        </div>
                                                        <h5 class="fw-bold mb-2 text-dark text-truncate"
                                                            title="<%= exam.title %>">
                                                            <%= exam.title %>
                                                        </h5>
                                                        <hr class="text-muted">
                                                        <div
                                                            class="d-flex justify-content-between align-items-center mt-3">
                                                            <span class="text-danger fw-semibold small">Pass Marks: <%=
                                                                    exam.passingMarks %></span>
                                                            <a href="/admin/results/<%= exam._id %>"
                                                                class="btn btn-primary btn-sm px-3 fw-bold shadow-sm">
                                                                View Scoreboard <i class="bi bi-arrow-right-short"></i>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="col-12 text-center py-5">
                                                        <i class="bi bi-folder2-open text-muted"
                                                            style="font-size: 3rem;"></i>
                                                        <p class="mt-3 text-muted fs-5">No exams found to display
                                                            results.</p>
                                                    </div>
                                                    <% } %>
                                </div>

                </main>
        </div>
    </div>

    <style>
        .custom-card {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }

        .custom-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
        }
    </style>

    <%- include('../../layouts/footer') %>