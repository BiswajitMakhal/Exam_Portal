<%- include('../../layouts/header') %>

    <div class="container-fluid">
        <div class="row">
            <%- include('../../layouts/sidebar') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="min-height: 100vh;">
                    <%- include('../../layouts/navbar') %>

                        <div
                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-2 mb-4 border-bottom">
                            <h1 class="h3 fw-bold"><i class="bi bi-plus-circle text-primary"></i> Create Exam</h1>
                            <a href="/admin/exams" class="btn btn-sm btn-outline-secondary"><i
                                    class="bi bi-arrow-left"></i> Back to List</a>
                        </div>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="alert alert-danger">
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="card p-4 shadow-sm border-0 col-lg-8 mb-4">
                                    <form action="/admin/exams/create" method="POST">
                                        <div class="mb-3">
                                            <label for="title" class="form-label fw-semibold">Exam Title <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" class="form-control" id="title" name="title"
                                                placeholder="e.g. Node.js Backend Assessment" required>
                                        </div>

                                        <div class="mb-3">
                                            <label for="description" class="form-label fw-semibold">Description</label>
                                            <textarea class="form-control" id="description" name="description" rows="3"
                                                placeholder="Brief instructions or syllabus..."></textarea>
                                        </div>

                                        <div class="row g-3 mb-3">
                                            <div class="col-12 col-md-4">
                                                <label for="duration" class="form-label fw-semibold">Duration (Minutes)
                                                    <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="duration" name="duration"
                                                    min="1" required>
                                            </div>
                                            <div class="col-12 col-md-4">
                                                <label for="passingMarks" class="form-label fw-semibold">Passing Marks
                                                    <span class="text-danger">*</span></label>
                                                <input type="number" class="form-control" id="passingMarks"
                                                    name="passingMarks" min="1" required>
                                            </div>
                                            <div class="col-12 col-md-4">
                                                <label for="status" class="form-label fw-semibold">Status <span
                                                        class="text-danger">*</span></label>
                                                <select class="form-select" id="status" name="status" required>
                                                    <option value="Draft" selected>Draft</option>
                                                    <option value="Active">Active</option>
                                                    <option value="Completed">Completed</option>
                                                </select>
                                            </div>
                                        </div>

                                        <div class="mt-4">
                                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i>
                                                Save Exam</button>
                                            <a href="/admin/exams" class="btn btn-light border ms-2">Cancel</a>
                                        </div>
                                    </form>
                                </div>
                </main>
        </div>
    </div>

    <%- include('../../layouts/footer') %>